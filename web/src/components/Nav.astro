<nav class="sticky top-0 z-30 bg-white/85 backdrop-blur-md border-b border-line">
  <div class="wrap flex items-center justify-between h-[60px]">
    <div class="flex items-center gap-[9px] font-head font-black text-[17px]">
      <Logo />
