---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "HearCat — 会議の声が、いま文字になる。",
  description = "自分の声と通話相手の声をリアルタイムで日本語文字起こしする、Mac 用メニューバーアプリ。録音・要約もすべて端末内で完結。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@500;700;900&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
